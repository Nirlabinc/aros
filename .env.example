# Copy to .env and fill values
APP_ENV=development
PORT=3000
# Required before mounting the internal ADP or task control-plane routers.
AROS_INTERNAL_API_TOKEN=

# Keep unset in normal operation. Only isolated LAN devices with self-signed
# certificates may opt in while a trusted CA/certificate is being installed.
AROS_ALLOW_INSECURE_VERIFONE_TLS=0

# Enable only when reachable exclusively through a trusted reverse proxy that
# overwrites X-Real-IP and appends X-Forwarded-For.
AROS_TRUST_PROXY=0
